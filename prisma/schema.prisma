datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
}

model Feature {
  id          Int     @id @default(autoincrement())
  title       String
  description String
}

model Transaction {
  id          Int      @id @default(autoincrement())
  date        DateTime // Tanggal transaksi
  description String   // Keterangan (misal: Beli Kopi)
  amount      Float    // Jumlah uang
  type        String   // Income (Pemasukan) atau Expense (Pengeluaran)
  category    String?  // Kategori (Opsional)
  createdAt   DateTime @default(now())
}